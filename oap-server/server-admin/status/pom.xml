<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>server-admin</artifactId>
        <groupId>org.apache.skywalking</groupId>
        <version>${revision}</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>status</artifactId>
    <packaging>jar</packaging>

    <dependencies>
        <!--
          admin-server is consulted reflectively at start() time via
          moduleManager.has(AdminServerModule.NAME). The dep is required at
          compile-time for the constant lookup; the runtime binding is
          conditional so a deployment can run status without admin-server
          enabled (e.g., the UI continues to call /status/* on the public
          REST port even when SW_ADMIN_SERVER is empty).
        -->
        <dependency>
            <groupId>org.apache.skywalking</groupId>
            <artifactId>admin-server</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!--
          query-graphql-plugin: status reuses the GraphQL resolvers' query
          services to render trace / topology / log / mqe debugging payloads
          on the HTTP debug-trace endpoints.
        -->
        <dependency>
            <groupId>org.apache.skywalking</groupId>
            <artifactId>query-graphql-plugin</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!--
          zipkin-query-plugin: zipkin-compat debug-trace endpoints route
          through the same handlers Zipkin queries do.
        -->
        <dependency>
            <groupId>org.apache.skywalking</groupId>
            <artifactId>zipkin-query-plugin</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!--
          server-alarm-plugin: alarm runtime status queries inspect the
          alarm provider's in-memory rule + window state.
        -->
        <dependency>
            <groupId>org.apache.skywalking</groupId>
            <artifactId>server-alarm-plugin</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
